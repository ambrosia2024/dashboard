DJANGO_SECRET_KEY=your_django_secret

POSTGRES_DB=ambrosia
POSTGRES_USER=amb_admin
POSTGRES_PASSWORD=password
POSTGRES_HOST=ambrosia_postgres
POSTGRES_PORT=5432
PGADMIN_DEFAULT_EMAIL=youremail@domain.com
PGADMIN_DEFAULT_PASSWORD=password

#FSKX_USERNAME=
#FSKX_PASSWORD=

CROP_ONTO_CONNECT_TIMEOUT=5
READ_TIMEOUT=45

SKIP_CROP_FETCH=0

SCIO_VOCAB_API_BASE
SCIO_NUTS_API_BASE
SCIO_MODELS_API_URL

# Authentication hardening
PUBLIC_SIGNUP_ENABLED=false
LOGIN_BURST_LIMIT_PER_MINUTE=20
SECURE_HSTS_SECONDS=31536000
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Ambra (OpenAI-compatible endpoint)
LLM_URL=
LLM_API_KEY=
LLM_MODEL=qwen3-30b-a3b-awq
LLM_CHAT_ENDPOINT=/v1/chat/completions
LLM_MAX_TOKENS=2048
LLM_MAX_USER_CHARS=1000
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=180
