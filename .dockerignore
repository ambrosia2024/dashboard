# Version-control metadata
.git/
.gitignore
.gitattributes
.github/
.gitlab-ci.yml

# Docker and deployment files that are not copied into the runtime image
.dockerignore
Dockerfile~
build_and_push.sh
docker-compose*.yml
nginx.conf
postgres/
mongodb/

# Python build, cache, and virtualenv files
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
.venv/
venv/
env/
ENV/
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Test, coverage, and tooling caches
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.cache/
**/tests/
**/test_*.py
**/*_test.py

# Environment, credentials, local databases, and logs
.env
.env.*
*.sqlite3
*.db
*.log
celerybeat-schedule
data/celery/

# IDE, editor, and OS files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Frontend dependency caches and package-manager noise
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local data, generated assets, and non-runtime folders
media/
assets/
data/
!static/data/
!static/data/**
synda/
testing/
api_test/
pidrive/
deliverables/
docs/

# Large or local-only data exports
/*.nc
*.bin
*.deb
*.csv
*.json
*.xlsx
*.xls
*.txt

# Markdown docs are not required at runtime.
**/*.md
