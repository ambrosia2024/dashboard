# Ignore Python virtual environment
.venv
venv/

# Ignore PostgreSQL directory
postgres/

# Ignore compiled Python files
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.sqlite3

# Ignore environment and secret files
.env
.env.local
.env.docker
.env.sample
*.log

# Ignore IDE/editor config files
.vscode/
.idea/
*.swp
*.swo

# Ignore Docker build cache
.dockerignore
Dockerfile~

.DS_Store
.git
.gitignore
docker-compose.yml
docker-compose.prod.yml
nginx/

media/
data/
!static/data/
!static/data/**
synda/
testing/
api_test/
pidrive/

/*.nc

deliverables/
docs/

# Ignore markdown docs (every level — none are needed at runtime)
**/*.md
